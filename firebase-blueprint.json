{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Représente une entreprise cliente multi-sites.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nom de l'entreprise" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Profil utilisateur avec rôle RBAC.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string", "description": "ID du tenant associé" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "auditor", "reader", "process_owner"] },
        "name": { "type": "string" }
      },
      "required": ["tenantId", "email", "role", "name"]
    },
    "Audit": {
      "title": "Audit",
      "description": "Un audit ISO 9001 planifié ou en cours.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["planned", "in-progress", "completed", "closed"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "leadAuditorId": { "type": "string" }
      },
      "required": ["tenantId", "name", "status", "startDate", "endDate", "leadAuditorId"]
    },
    "Finding": {
      "title": "Finding",
      "description": "Constat d'audit lié à une exigence.",
      "type": "object",
      "properties": {
        "auditId": { "type": "string" },
        "exigenceId": { "type": "string" },
        "status": { "type": "string", "enum": ["C", "OA", "OBS", "NCm", "NCM", "NA"] },
        "constat": { "type": "string" },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["auditId", "exigenceId", "status", "constat", "riskLevel", "updatedAt"]
    },
    "Evidence": {
      "title": "Evidence",
      "description": "Preuve documentaire liée à un audit.",
      "type": "object",
      "properties": {
        "auditId": { "type": "string" },
        "name": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["auditId", "name", "fileUrl", "uploadedBy", "uploadedAt"]
    },
    "NonConformity": {
      "title": "NonConformity",
      "description": "Action corrective liée à un écart.",
      "type": "object",
      "properties": {
        "auditId": { "type": "string" },
        "findingId": { "type": "string" },
        "type": { "type": "string", "enum": ["NCm", "NCM"] },
        "status": { "type": "string", "enum": ["open", "in-progress", "verified", "closed"] },
        "dueDate": { "type": "string", "format": "date" },
        "responsibleId": { "type": "string" }
      },
      "required": ["auditId", "findingId", "type", "status", "dueDate", "responsibleId"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": { "schema": "Tenant", "description": "Données du tenant" },
    "/users/{userId}": { "schema": "User", "description": "Profils utilisateurs" },
    "/audits/{auditId}": { "schema": "Audit", "description": "Liste des audits" },
    "/findings/{findingId}": { "schema": "Finding", "description": "Constats d'audit" },
    "/evidences/{evidenceId}": { "schema": "Evidence", "description": "Preuves documentaires" },
    "/non_conformities/{ncId}": { "schema": "NonConformity", "description": "Suivi des NC" }
  }
}
