{
  "entities": {
    "Audit": {
      "title": "Audit",
      "description": "Represents an audit session for a company",
      "type": "object",
      "properties": {
        "companyName": { "type": "string", "description": "Name of the audited company" },
        "structure": { "type": "string", "description": "Audited structure or department" },
        "auditorName": { "type": "string", "description": "Name of the auditor" },
        "date": { "type": "string", "format": "date", "description": "Date of the audit" },
        "status": { "type": "string", "enum": ["draft", "completed"], "description": "Current status of the audit" },
        "createdBy": { "type": "string", "description": "UID of the user who created the audit" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyName", "auditorName", "date", "createdBy"]
    },
    "Finding": {
      "title": "Finding",
      "description": "An audit finding for a specific requirement",
      "type": "object",
      "properties": {
        "auditId": { "type": "string", "description": "Reference to the parent audit" },
        "requirementId": { "type": "string", "description": "ID of the ISO requirement (e.g., 4.1.1)" },
        "rating": { "type": "string", "description": "Rating code (C, OBS, etc.)" },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
        "comment": { "type": "string", "description": "Observation text" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["auditId", "requirementId", "rating"]
    }
  },
  "firestore": {
    "/audits/{auditId}": {
      "schema": "Audit",
      "description": "Collection of audits"
    },
    "/audits/{auditId}/findings/{findingId}": {
      "schema": "Finding",
      "description": "Findings for a specific audit"
    }
  }
}
