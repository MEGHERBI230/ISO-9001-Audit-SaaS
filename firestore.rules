rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.createdBy;
    }

    function isValidAudit(data) {
      return data.companyName is string && data.companyName.size() > 0 && data.companyName.size() < 200 &&
             data.auditorName is string && data.auditorName.size() > 0 &&
             data.createdBy == request.auth.uid &&
             (!('objectives' in data) || data.objectives is string) &&
             (!('scope' in data) || data.scope is string) &&
             (!('strengths' in data) || data.strengths is list) &&
             (!('weaknesses' in data) || data.weaknesses is list);
    }

    function isValidFinding(data) {
      return data.auditId is string &&
             data.requirementId is string &&
             data.rating is string &&
             (!('riskLevel' in data) || data.riskLevel in ['low', 'medium', 'high']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /audits/{auditId} {
      allow read: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow create: if isAuthenticated() && isValidAudit(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidAudit(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();

      match /findings/{findingId} {
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/audits/$(auditId)).data.createdBy == request.auth.uid;
        allow write: if isAuthenticated() && get(/databases/$(database)/documents/audits/$(auditId)).data.createdBy == request.auth.uid && isValidFinding(request.resource.data);
      }
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
